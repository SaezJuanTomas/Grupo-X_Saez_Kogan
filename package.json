{
  "name": "grupo-x-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "tsc && node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "backend:install": "cd backend && pip install -r requirements.txt",
    "backend:seed": "cd backend && python -m backend.seed",
    "backend:dev": "cd backend && python -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "backend:docs": "cd backend && python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "fullstack:dev": "concurrently \"npm run dev\" \"npm run backend:dev\"",
    "setup": "npm install && npm run backend:install && npm run backend:seed"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
